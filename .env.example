# Gmail OAuth2 credentials
# Get from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret

# Get by running: npm run get-token
GMAIL_REFRESH_TOKEN=your-refresh-token

# Google Gemini API key (free tier: 1500 req/day)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Email address to receive daily reports
REPORT_EMAIL=work4aarun@gmail.com
GMAIL_USER_EMAIL=Techifynow@gmail.com

# Scan settings (optional, have defaults)
SCAN_HOURS_BACK=24
SCAN_MAX_EMAILS=200
OUTPUT_DIR=./reports
